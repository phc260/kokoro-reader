{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kokoro-reader",
  "version": "0.1.2",
  "identifier": "com.phc260.kokoro-reader",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420/",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kokoro-reader",
        "width": 400,
        "height": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../kokoro-sapi/build/KokoroSapi.dll": "resources/KokoroSapi.dll",
      "../kokoro-sapi/kindle-voice-guard.ps1": "resources/kindle-voice-guard.ps1"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
